PUBLIC_SITE_URL=https://tuneyourvibration.com

# MCP Server Configuration (optional for local AI tooling)

# Gemini AI - Google's AI model with code execution and search capabilities
GEMINI_API_KEY=your_gemini_api_key_here
ENABLE_GEMINI_TOOLS=true
ENABLE_CODE_EXECUTION=true
ENABLE_GOOGLE_SEARCH=true

# Firecrawl - Web scraping and crawling tool
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Perplexity - AI-powered search and research
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Context7 - Context and memory management by Upstash
CONTEXT7_API_KEY=your_context7_api_key_here

# DataForSEO - SEO data and analytics API
DATAFORSEO_USERNAME=your_dataforseo_username_here
DATAFORSEO_PASSWORD=your_dataforseo_password_here
