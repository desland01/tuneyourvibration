---
import { IoSearch } from "react-icons/io5";
import { primaryNavLinks, virtualSessionsNav } from "@/lib/navLinks";
import AmbientAudio from "@components/base/AmbientAudio.astro";

const { pathname } = Astro.url;

const stickyHeader = true;

const menu = primaryNavLinks.map((item) =>
  item.name === "Virtual Sessions"
    ? { ...item, children: virtualSessionsNav.slice(1) }
    : item,
);

type AmbientSlot = { ambient: true };
type MenuEntry = (typeof menu)[number] | AmbientSlot;

const menuWithAmbient: MenuEntry[] = menu.flatMap((item) =>
  item.name === "Blog" ? [item, { ambient: true }] : [item],
);

const isActive = (path: string, item: (typeof menu)[number]) => {
  if (path === item.url || `${path}/` === item.url || path === `${item.url}/`) {
    return true;
  }
  if (item.children) {
    return item.children.some(
      (child) =>
        path === child.url ||
        `${path}/` === child.url ||
        path === `${child.url}/`,
    );
  }
  return false;
};
---

<header
  transition:persist
  class={`container glass relative py-2 mb-3 lg:mt-3 lg:rounded-lg ${stickyHeader ? "sticky top-0 z-50 backdrop-blur-xl" : "z-30"}`}
>
  <nav class="relative flex flex-wrap items-center justify-between">
    <!-- navbar toggler -->
    <input id="nav-toggle" type="checkbox" class="hidden" />
    <label
      for="nav-toggle"
      class="order-0 cursor-pointer flex items-center md:hidden text-txt-p dark:text-darkmode-txt-p lg:order-1"
    >
      <svg id="show-button" class="h-6 fill-current block" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
      <svg id="hide-button" class="h-6 fill-current hidden" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"></polygon>
      </svg>
    </label>
    <!-- /navbar toggler -->
    <ul
      id="nav-menu"
      class="text-center lg:text-left order-3 hidden w-full flex-col gap-2 pb-6 md:order-1 md:flex md:w-auto md:flex-row md:items-center md:gap-2 md:pb-0 lg:gap-4"
    >
      {menuWithAmbient.map((item) =>
        "ambient" in item ? (
          <li class="flex justify-center px-2 py-2 md:px-0 md:py-0 md:pl-2 md:items-center">
            <AmbientAudio placement="inline" className="md:ml-2" />
          </li>
        ) : (
          <li class={`relative ${item.children ? "group" : ""}`}>
            <a
              href={item.url}
              class={`flex items-center justify-between gap-2 rounded-lg px-3 py-2 font-secondary font-semibold text-[#fff9ff] transition hover:bg-bg-s/40 dark:text-[#fef4ff] dark:hover:bg-darkmode-bg-s/40 lg:px-3 lg:py-3 ${
                isActive(pathname, item) ? "active" : ""
              }`}
            >
              {item.name}
              {item.children && (
                <svg
                  class="h-4 w-4 text-[#e8dbff]/80 transition-transform group-hover:rotate-180 dark:text-[#f4e8ff]/80 md:h-3 md:w-3"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.084l3.71-3.853a.75.75 0 0 1 1.08 1.04l-4.243 4.4a.75.75 0 0 1-1.08 0l-4.243-4.4a.75.75 0 0 1 .02-1.06z" />
                </svg>
              )}
            </a>
            {item.children && (
              <>
                <div class="mt-1 space-y-1 rounded-2xl border border-border/40 bg-[#5b3aa3] bg-opacity-95 p-3 text-left shadow-lg dark:border-darkmode-border/40 dark:bg-[#2f1d5d] dark:bg-opacity-95 md:hidden">
                  {item.children.map((child) => (
                    <a
                      href={child.url}
                      class="block rounded-lg px-3 py-2 text-sm text-[#fff9ff] transition hover:bg-[#6a46ba]/90 dark:text-[#fef4ff] dark:hover:bg-[#3a2574]/90"
                    >
                      {child.name}
                    </a>
                  ))}
                </div>
                <div class="hidden md:absolute md:left-0 md:top-full md:z-40 md:min-w-72 md:translate-y-0 md:rounded-2xl md:border md:border-border/40 md:bg-[#5b3aa3] md:bg-opacity-95 md:p-3 md:shadow-2xl md:transition md:duration-150 md:ease-out md:group-hover:block md:group-focus-within:block dark:md:border-darkmode-border/40 dark:md:bg-[#2f1d5d] dark:md:bg-opacity-95">
                  {item.children.map((child) => (
                    <a
                      href={child.url}
                      class="block rounded-xl px-4 py-2 text-sm font-medium text-[#fff9ff] transition hover:bg-[#6a46ba]/90 dark:text-[#fef4ff] dark:hover:bg-[#3a2574]/90"
                    >
                      {child.name}
                    </a>
                  ))}
                </div>
              </>
            )}
          </li>
        ),
      )}
    </ul>
    <div class="order-1 ml-auto flex items-center md:order-2 lg:ml-0">
      <a
        class="mr-4 inline-block border-border text-xl text-txt-p dark:border-darkmode-border dark:text-darkmode-txt-p"
        href="/search"
        aria-label="search"
      >
        <IoSearch />
      </a>
    </div>
  </nav>
</header>
