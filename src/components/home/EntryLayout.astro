---
import BaseLayout from "@components/base/BaseLayout.astro";
import Button from "@components/common/Button.astro";
import TestimonialsGrid from "@components/common/TestimonialsGrid.astro";
import Card from "@components/services/Card.astro";
import type { HomeEntry, ServicesEntry } from "@/types";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { googleReviews } from "@/lib/googleReviews";

interface Props {
  entry: HomeEntry;
}

const { entry } = Astro.props;
const data = entry.data;

const resolveCta = (cta: HomeEntry["data"]["hero"]["primaryCta"]) => {
  const link =
    cta.type === "email" && !cta.link.startsWith("mailto:")
      ? `mailto:${cta.link}`
      : cta.link;
  return {
    label: cta.label,
    link,
    newtab: cta.type !== "internal",
  };
};

const heroPrimary = resolveCta(data.hero.primaryCta);
const heroSecondary = data.hero.secondaryCta
  ? resolveCta(data.hero.secondaryCta)
  : null;

const services = (await getCollection(
  "services",
  ({ data }) => !data.draft,
)) as ServicesEntry[];

const featuredServices = data.offerings.featuredSlugs
  .map((slug) => services.find((service) => service.data.slug === slug))
  .filter(Boolean) as ServicesEntry[];

const virtualAnchor = services.find((service) => service.data.slug === "virtual-sound-healing");
const testimonials =
  data.testimonials && data.testimonials.length > 0
    ? data.testimonials
    : googleReviews;
---

<BaseLayout
  title={data.seoTitle ?? data.hero.title}
  description={data.seoDescription ?? data.hero.subtitle}
>
  <section class="section pt-8 lg:pt-12">
    <div class="container">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-center">
        <div class="space-y-5">
          <span class="inline-block rounded-full border border-border/60 px-4 py-1 text-xs uppercase tracking-[0.35em] glow-caption">
            {data.hero.eyebrow}
          </span>
          <h1 class="text-h2 md:text-h1 glow-heading hero-heading">
            {data.hero.title}
          </h1>
          <p class="text-lg leading-relaxed glow-body">
            {data.hero.subtitle}
          </p>
          {data.hero.supportingPoints.length > 0 && (
            <ul class="grid gap-3 text-base">
              {data.hero.supportingPoints.map((point) => (
                <li class="glass flex items-start gap-3 rounded-[20px] px-4 py-3">
                  <span class="mt-1 inline-block h-2 w-2 rounded-full bg-white shadow-[0_0_12px_rgba(255,255,255,0.6)]" />
                  <span class="glow-body">{point}</span>
                </li>
              ))}
            </ul>
          )}
          <div class="flex flex-wrap gap-4">
            <Button label={heroPrimary.label} link={heroPrimary.link} newtab={heroPrimary.newtab} />
            {heroSecondary && (
              <Button
                label={heroSecondary.label}
                link={heroSecondary.link}
                newtab={heroSecondary.newtab}
                type="secondary"
              />
            )}
          </div>
        </div>
        <div class="mx-auto w-full max-w-[480px]">
          {data.hero.image && (
            <div class="relative aspect-[4/5] overflow-hidden rounded-[32px] border border-border/40 bg-gradient-to-br from-bg-s/60 to-bg-s/10 shadow-[0_32px_60px_rgba(9,2,24,0.4)] dark:border-darkmode-border/40">
              <Image
                src={data.hero.image}
                alt={data.hero.imageAlt}
                width={960}
                height={1200}
                sizes="(min-width: 1280px) 480px, (min-width: 1024px) 42vw, (min-width: 640px) 55vw, 88vw"
                class="h-full w-full object-cover"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
          )}
        </div>
      </div>
      {data.trustSignals.length > 0 && (
        <div class="glass mt-12 rounded-[32px] px-6 py-8">
          <div class="grid gap-6 text-sm leading-relaxed text-txt-light dark:text-darkmode-txt-light md:grid-cols-3">
            {data.trustSignals.map((signal) => (
              <p class="text-center">{signal}</p>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  {data.benefits.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="row justify-center text-center mb-8">
          <div class="lg:col-8">
            <h2 class="text-h3 font-primary text-txt-p dark:text-darkmode-txt-p">
              What shifts in a session
            </h2>
          </div>
        </div>
        <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
          {data.benefits.map((benefit) => (
            <div class="glass flex h-full w-full flex-col items-center gap-3 rounded-3xl border border-border/40 p-5 text-center dark:border-darkmode-border/40">
              <div class="flex h-12 w-12 items-center justify-center rounded-full border border-border/60 bg-bg-t/50 text-xl dark:border-darkmode-border/60">
                ✦
              </div>
              <div class="space-y-2">
                <h3 class="text-xl font-semibold text-txt-p dark:text-darkmode-txt-p">
                  {benefit.title}
                </h3>
                <p class="text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
                  {benefit.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {featuredServices.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="row justify-center text-center mb-8">
          <div class="lg:col-8">
            <h2 class="text-h3 font-primary text-txt-p dark:text-darkmode-txt-p mb-3">
              {data.offerings.heading}
            </h2>
            {data.offerings.description && (
              <p class="text-base text-txt-p/80 dark:text-darkmode-txt-p/80">
                {data.offerings.description}
              </p>
            )}
          </div>
        </div>
        <div class="grid gap-10 sm:grid-cols-2 xl:grid-cols-3">
          {featuredServices.map((service) => (
            <Card entry={service} highlight={service.data.slug === "virtual-sound-healing"} />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-11">
          <div class="glass rounded-[32px] p-8 md:p-10">
            <div class="grid gap-6 lg:grid-cols-4 lg:items-start">
              <div class="space-y-4">
                <h2 class="text-h3 font-primary text-txt-p dark:text-darkmode-txt-p">
                  {data.journey.heading}
                </h2>
                <p class="text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
                  {data.journey.subtitle}
                </p>
              </div>
              <div class="lg:col-span-3">
                <ol class="grid gap-10 sm:grid-cols-2 xl:grid-cols-3">
                  {data.journey.steps.map((step, index) => (
                    <li class="flex w-full flex-col gap-3 rounded-3xl border border-border/40 bg-bg-s/40 p-4 text-left dark:border-darkmode-border/40 dark:bg-darkmode-bg-s/40">
                      <span class="text-xs font-semibold uppercase tracking-[0.38em] text-txt-light dark:text-darkmode-txt-light">
                        Step {String(index + 1).padStart(2, "0")}
                      </span>
                      <div>
                        <h3 class="text-base font-primary text-txt-p dark:text-darkmode-txt-p">
                          {step.title}
                        </h3>
                        <p class="mt-3 text-sm leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
                          {step.description}
                        </p>
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {data.gallery && data.gallery.images.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="row justify-center text-center mb-8">
          <div class="lg:col-8">
            <h2 class="text-h3 font-primary text-txt-p dark:text-darkmode-txt-p mb-3">
              {data.gallery.heading}
            </h2>
            {data.gallery.subtitle && (
              <p class="text-base text-txt-p/80 dark:text-darkmode-txt-p/80">
                {data.gallery.subtitle}
              </p>
            )}
          </div>
        </div>
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
          {data.gallery.images.map((photo) => (
            <div class="glass flex h-full w-full flex-col overflow-hidden rounded-3xl border border-border/40 dark:border-darkmode-border/40">
              <div class="relative aspect-[4/5] w-full overflow-hidden">
                <Image
                  src={photo.image}
                  alt={photo.alt}
                  width={600}
                  height={750}
                  sizes="(min-width: 1280px) 320px, (min-width: 1024px) 28vw, (min-width: 640px) 45vw, 88vw"
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              {photo.caption && (
                <p class="px-6 py-5 text-sm text-center leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
                  {photo.caption}
                </p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <TestimonialsGrid
    testimonials={testimonials}
    heading="Client Reflections"
  />

  <section class="section pb-12">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8 text-center">
          <div class="glass rounded-3xl p-8">
            <h2 class="text-h3 font-primary mb-4 text-txt-p dark:text-darkmode-txt-p">
              {data.closing.heading}
            </h2>
            <p class="text-base text-txt-p/80 dark:text-darkmode-txt-p/80 mb-6">
              {data.closing.copy}
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <Button
                label={data.closing.primaryCta.label}
                link={
                  data.closing.primaryCta.type === "email" &&
                  !data.closing.primaryCta.link.startsWith("mailto:")
                    ? `mailto:${data.closing.primaryCta.link}`
                    : data.closing.primaryCta.link
                }
                newtab={data.closing.primaryCta.type !== "internal"}
              />
              {data.closing.secondaryCta && (
                <Button
                  label={data.closing.secondaryCta.label}
                  link={
                    data.closing.secondaryCta.type === "email" &&
                    !data.closing.secondaryCta.link.startsWith("mailto:")
                      ? `mailto:${data.closing.secondaryCta.link}`
                      : data.closing.secondaryCta.link
                  }
                  newtab={data.closing.secondaryCta.type !== "internal"}
                  type="secondary"
                />
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
