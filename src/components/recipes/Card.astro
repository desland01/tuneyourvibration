---
import { Image } from "astro:assets";
import type { RecipesEntry } from "@/types";
import { resolveImage } from "@/lib/resolveImage";

interface Props {
  entry: RecipesEntry;
}

const { entry } = Astro.props;
const { title, image, imageAlt } = entry.data;
const cardImage = resolveImage(image);
const cardWidth = cardImage?.width ?? 1280;
const cardHeight = cardImage?.height ?? 720;
---

<div
  class="h-full m-2 pl-0 bg-gradient-to-br gradient rounded-lg intersect:animate-fadeUp opacity-0"
>
  <div class="glass h-full rounded-lg">
    <a class="group hover:opacity-100" href={`/recipes/${entry.id}`}>
      <div class="relative rounded-lg pb-9/16 overflow-hidden">
        {
          (cardImage || image) && (
            cardImage ? (
              <Image
                class="absolute rounded-lg object-cover w-full h-full group-hover:scale-[105%] transition-all duration-300"
                src={cardImage}
                alt={imageAlt}
                width={cardWidth}
                height={cardHeight}
                sizes="(min-width: 1280px) 380px, (min-width: 1024px) 32vw, 90vw"
                loading="eager"
                decoding="async"
              />
            ) : (
              <img
                class="absolute rounded-lg object-cover w-full h-full group-hover:scale-[105%] transition-all duration-300"
                src={typeof image === "string" ? image : image?.src}
                alt={imageAlt}
                loading="eager"
                decoding="async"
              />
            )
          )
        }
        <div
          class="glass-t absolute text-center rounded-lg px-2 py-1 top-[50%] left-[50%] -translate-x-[50%] -translate-y-[50%]"
        >
          <h4 class="">
            {title}
          </h4>
        </div>
      </div>
    </a>
  </div>
</div>
