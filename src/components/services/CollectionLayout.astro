---
import BaseLayout from "@components/base/BaseLayout.astro";
import Button from "@components/common/Button.astro";
import Card from "@components/services/Card.astro";
import type { ServicesEntry } from "@/types";
import { Image } from "astro:assets";
import { resolveImage } from "@/lib/resolveImage";

interface ServiceGroup {
  id: string;
  heading: string;
  description?: string;
  entries: ServicesEntry[];
  layout?: "grid" | "list";
}

interface Props {
  title: string;
  description?: string;
  groups: ServiceGroup[];
}

const { title, description, groups } = Astro.props;

const formatPrice = (price?: number, currency?: string) => {
  if (price === undefined) return null;
  try {
    return new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: currency ?? "USD",
      maximumFractionDigits: 0,
    }).format(price);
  } catch {
    return `${currency ?? "USD"} ${price}`;
  }
};

const resolveCta = (data: ServicesEntry["data"]) => {
  const cta = data.cta;
  if (!cta) {
    return { link: "/services", newtab: false, label: "Explore Services" };
  }

  if (cta.type === "whatsapp") {
    return { link: cta.value, newtab: true, label: cta.label };
  }

  if (cta.type === "email") {
    return { link: `mailto:${cta.value}`, newtab: false, label: cta.label };
  }

  return { link: cta.value, newtab: false, label: cta.label };
};

const getGridClass = (groupId: string) =>
  groupId === "in-person-kathmandu"
    ? "grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-2 2xl:grid-cols-4"
    : "grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4";

const normalizeBenefit = (value: any) =>
  typeof value === "string"
    ? value
    : typeof value?.title === "string"
      ? value.title
      : JSON.stringify(value);

---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container">
      <div class="row justify-center text-center mb-12">
        <div class="lg:col-10">
          <h1 class="mb-4 text-4xl font-bold glow-heading hero-heading">
            {title}
          </h1>
          {description && (
            <p class="text-lg glow-body max-w-3xl mx-auto">
              {description}
            </p>
          )}
        </div>
      </div>
      {groups.map((group) => (
        <section id={group.id} class="mb-20">
          <div class="mx-auto mb-8 max-w-3xl text-center">
            <h2 class="text-3xl font-semibold glow-heading">
              {group.heading}
            </h2>
            {group.description && (
              <p class="mt-3 text-base leading-relaxed glow-body">
                {group.description}
              </p>
            )}
          </div>
          {group.id === "group" && group.entries.length === 1 ? (
            (() => {
              const entry = group.entries[0];
              const data = entry.data;
              const priceLabel = formatPrice(data.price, data.currency);
              const cta = resolveCta(data);
              const labelChips = [
                data.duration,
                data.location,
                priceLabel ? `Exchange: ${priceLabel}` : null,
              ].filter(Boolean);
              const featureImage = resolveImage(data.image);
              const featureWidth = featureImage?.width ?? 640;
              const featureHeight = featureImage?.height ?? 800;
              return (
                <div class="glass rounded-[40px] border border-border/40 p-8 md:p-12 dark:border-darkmode-border/40">
                  <div class="flex flex-col gap-10 lg:flex-row lg:items-center">
                    {(featureImage || data.image) && (
                      <div class="mx-auto w-full max-w-[420px] overflow-hidden rounded-[32px] border border-border/40 bg-bg-s/40 dark:border-darkmode-border/40 dark:bg-darkmode-bg-s/40">
                        <div class="relative aspect-[4/5] w-full">
                          {featureImage ? (
                            <Image
                              src={featureImage}
                              alt={data.imageAlt}
                              width={featureWidth}
                              height={featureHeight}
                              sizes="(min-width: 1280px) 360px, (min-width: 1024px) 32vw, 80vw"
                              class="h-full w-full object-cover"
                              loading="lazy"
                              decoding="async"
                            />
                          ) : (
                            <img
                              src={typeof data.image === "string" ? data.image : data.image?.src}
                              alt={data.imageAlt}
                              class="h-full w-full object-cover"
                              loading="lazy"
                              decoding="async"
                            />
                          )}
                        </div>
                      </div>
                    )}
                    <div class="mx-auto flex w-full max-w-2xl flex-col gap-6 text-center lg:text-left">
                      <div class="space-y-4">
                        <span class="text-xs font-semibold uppercase tracking-[0.35em] glow-caption">
                          Group Ceremony
                        </span>
                        <h3 class="text-4xl font-bold glow-heading">
                          {data.title}
                        </h3>
                        <p class="text-lg leading-relaxed glow-body">
                          {data.summary}
                        </p>
                        {labelChips.length > 0 && (
                          <div class="flex flex-wrap justify-center gap-3 text-sm glow-caption lg:justify-start">
                            {labelChips.map((chip) => (
                              <span class="rounded-full border border-border/40 px-4 py-1.5 dark:border-darkmode-border/40">
                                {chip}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                      {data.benefits?.length ? (
                        <div class="grid gap-3 text-left text-sm leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80 lg:grid-cols-3">
                          {data.benefits.map((benefit) => (
                            <div class="rounded-2xl border border-border/40 bg-bg-s/40 px-4 py-3 dark:border-darkmode-border/40 dark:bg-darkmode-bg-s/40">
                              {normalizeBenefit(benefit)}
                            </div>
                          ))}
                        </div>
                      ) : null}
                      <div class="flex flex-wrap justify-center gap-4 lg:justify-start">
                        <Button label={cta.label} link={cta.link} newtab={cta.newtab} />
                      </div>
                    </div>
                  </div>
                </div>
              );
            })()
          ) : (
            <div class={getGridClass(group.id)}>
              {group.entries.map((entry) => (
                <div class="h-full">
                  <Card entry={entry} highlight={entry.data.slug === "virtual-sound-healing"} />
                </div>
              ))}
            </div>
          )
          }
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
