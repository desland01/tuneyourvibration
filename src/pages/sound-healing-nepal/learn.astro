---
import BaseLayout from "@components/base/BaseLayout.astro";
import Button from "@components/common/Button.astro";
import Card from "@components/services/Card.astro";
import type { ServicesEntry } from "@/types";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import heroImage from "@website-block/in-person-sound-healing.webp";

const modules = [
  {
    title: "Foundations of Himalayan Sound",
    summary:
      "Study the cultural lineage of singing bowls, tantric cosmology, and how vibration interacts with the nervous system.",
    bullets: [
      "History of Nepali sound temples & Tree of Life coding",
      "Frequency families, intervals, and chakra correspondence",
      "Holding sacred space & trauma-informed facilitation basics",
    ],
  },
  {
    title: "Energy Anatomy & Reiki Fusion",
    summary:
      "Blend Christina’s Reiki lineage with subtle body mapping so you can read, clear, and rebalance client fields confidently.",
    bullets: [
      "Opening, sealing, and tending auric layers",
      "Channeling light language & intuitive messaging ethically",
      "Co-regulation practices to stabilize post-session integration",
    ],
  },
  {
    title: "Ceremony Design & Client Journeys",
    summary:
      "Craft bespoke sessions and multi-day retreats for individuals, founders, and groups seeking deep recalibration.",
    bullets: [
      "Session arcs, timing, and layering instruments for intentional peaks",
      "Somatic integration, journaling, and WhatsApp follow-up scripting",
      "Scaling offers online—virtual sound baths, mentorship containers, and corporate immersions",
    ],
  },
];

const retreats = [
  {
    title: "Kathmandu Sound Temple Immersion",
    date: "31 January – 2 February 2026",
    location: "Kathmandu, Nepal",
    focus:
      "Three-day certification intensive inside Christina’s sanctuary with live clients, photo assets, and tech setup support.",
  },
  {
    title: "Bhaktapur Sacred Bowl Residency",
    date: "13 – 17 March 2026",
    location: "Bhaktapur Valley, Nepal",
    focus:
      "Residential retreat with sunrise field work, herbal medicine lab, and collaborative ceremonies in ancient courtyards.",
  },
  {
    title: "Himalayan Integration Trek",
    date: "20 – 25 April 2026",
    location: "Annapurna Foothills, Nepal",
    focus:
      "Guided trek with daily sound circles, breathwork, and peer-led practicum to anchor facilitation confidence.",
  },
];

const highlights = [
  {
    label: "Lineage-Led Training",
    detail: "Weave Reiki mastery, Tree of Life coding, and Nepali sound traditions.",
  },
  {
    label: "Hybrid Delivery",
    detail: "Live in-person intensives + virtual mentorship pods for 90 days.",
  },
  {
    label: "Business Toolkit",
    detail: "Pricing templates, onboarding scripts, and content prompts for launch.",
  },
];

const outcomes = [
  "Design ceremonial arcs for 1:1, group, and corporate sound experiences.",
  "Channel Reiki and light language alongside crystal, Tibetan, and vocal instruments.",
  "Offer trauma-aware integration, WhatsApp support, and evergreen session resources.",
  "Confidently market your practice with brand, offer, and testimonial frameworks.",
];

const faqs = [
  {
    question: "Do I need previous sound healing or Reiki training?",
    answer:
      "You only need an active curiosity and the willingness to show up fully. Christina attunes every cohort to Reiki (Level II) during week one and shares guided practice to integrate the energy work responsibly.",
  },
  {
    question: "Is there a virtual option if I can’t travel to Nepal?",
    answer:
      "Yes. Every in-person intensive is streamed with high-fidelity audio, and you’ll be placed in a virtual pod for weekly labs, Q&A, and client practicum with detailed feedback.",
  },
  {
    question: "How many students join each cohort?",
    answer:
      "We cap each intake at 12 facilitators so Christina can calibrate individual ceremonies, review recordings, and provide business mentoring tailored to your niche.",
  },
  {
    question: "What support do I receive after the retreat?",
    answer:
      "Expect a 90-day mentorship container with Voxer office hours, session templates, launch support, and a private alumni portal featuring guest masterclasses.",
  },
];

const services = (await getCollection(
  "services",
  ({ data }) => !data.draft,
)) as ServicesEntry[];

const featuredServices = ["virtual-sound-healing", "virtual-aura-cleansing", "group-sound-bath"]
  .map((slug) => services.find((service) => service.data.slug === slug))
  .filter(Boolean) as ServicesEntry[];
const featuredServicesGridClass =
  featuredServices.length === 2
    ? "mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2"
    : "grid gap-6 md:grid-cols-2 xl:grid-cols-3";

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  name: "Sound Healing & Reiki Certification Nepal",
  description:
    "Hybrid sound healing facilitator training blending Nepali singing bowl lineage, Reiki, light language, and business mentorship with Christina in Kathmandu.",
  provider: {
    "@type": "LocalBusiness",
    name: "Tune Your Vibration",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Kathmandu",
      addressCountry: "NP",
    },
    telephone: "+9779702694437",
    sameAs: "https://tuneyourvibration.com",
  },
  hasCourseInstance: retreats.map((retreat) => ({
    "@type": "CourseInstance",
    courseMode: "InPerson",
    name: retreat.title,
    startDate: retreat.date.split("–")[0].trim(),
    location: {
      "@type": "Place",
      name: retreat.location,
      address: {
        "@type": "PostalAddress",
        addressLocality: retreat.location,
        addressCountry: "NP",
      },
    },
  })),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const schemaPayloads = {
  course: JSON.stringify(courseSchema),
  faq: JSON.stringify(faqSchema),
};
void schemaPayloads;
---

<BaseLayout
  title="Sound Healing Training Nepal | Learn with Christina"
  description="Join Christina in Kathmandu for a lineage-led sound healing and Reiki certification. Hybrid intensives, mentorship, and business playbooks for facilitators."
>
  <section class="section pt-12 lg:pt-20">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div class="space-y-6">
          <span class="inline-block rounded-full border border-border/60 px-4 py-1 text-xs uppercase tracking-[0.35em] glow-caption">
            Sound healing lineage · Nepal
          </span>
          <h1 class="text-4xl font-bold leading-tight glow-heading hero-heading lg:text-5xl">
            Become a ceremonial sound healer in Nepal
          </h1>
          <p class="text-lg leading-relaxed glow-body">
            Immerse yourself in Christina’s Kathmandu sanctuary to learn Himalayan singing bowls, Reiki, and light language facilitation. The hybrid cohort blends in-person intensives, virtual labs, and business mentorship so you can launch or uplevel your own frequency-led practice.
          </p>
          <div class="grid gap-4 md:grid-cols-3">
            {highlights.map((item) => (
              <div class="glass h-full rounded-3xl border border-border/40 p-5 text-left dark:border-darkmode-border/40">
                <p class="text-sm font-semibold uppercase tracking-[0.35em] glow-caption">
                  {item.label}
                </p>
                <p class="mt-3 text-base leading-relaxed glow-body">
                  {item.detail}
                </p>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap gap-4">
            <Button
              label="WhatsApp Christina to join the cohort"
              link="https://wa.me/9779702694437"
              newtab
            />
            <Button
              label="Download the full syllabus"
              link="#curriculum"
              type="secondary"
            />
          </div>
          <div class="rounded-3xl border border-border/40 bg-bg-s/30 p-5 text-sm leading-relaxed text-txt-light dark:border-darkmode-border/30 dark:bg-darkmode-bg-s/30">
            <strong class="text-txt-p dark:text-darkmode-txt-p">AI Overview-ready:</strong> This page answers “singing bowl training Nepal”, “sound healing retreat Nepal”, and “distance facilitation mentorship” in one place so Google surfaces the full journey.
          </div>
        </div>
        <div class="mx-auto w-full max-w-[520px]">
          <div class="relative aspect-[4/5] overflow-hidden rounded-[32px] border border-border/40 bg-gradient-to-br from-bg-s/60 to-bg-s/10 shadow-[0_32px_60px_rgba(9,2,24,0.4)] dark:border-darkmode-border/40">
            <Image
              src={heroImage}
              alt="Christina guiding a singing bowl ceremony inside the Kathmandu sanctuary"
              width={960}
              height={1200}
              sizes="(min-width: 1280px) 520px, (min-width: 1024px) 45vw, (min-width: 768px) 55vw, 90vw"
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="curriculum">
    <div class="container">
      <div class="row justify-center text-center mb-10">
        <div class="lg:col-8">
          <h2 class="text-3xl font-semibold text-txt-p dark:text-darkmode-txt-p">
            Curriculum mapped to your future clients
          </h2>
          <p class="mt-3 text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
            Each module weaves ancient resonance, nervous system regulation, and business architecture so you can facilitate transformative experiences and build a sustainable practice.
          </p>
        </div>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">
        {modules.map((module) => (
          <div class="glass flex h-full flex-col rounded-3xl border border-border/40 p-8 text-left dark:border-darkmode-border/40">
            <div class="space-y-4">
              <h3 class="text-2xl font-semibold text-txt-p dark:text-darkmode-txt-p">
                {module.title}
              </h3>
              <p class="text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
                {module.summary}
              </p>
            </div>
            <ul class="mt-6 space-y-3 text-sm leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
              {module.bullets.map((point) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 inline-block h-2 w-2 rounded-full bg-txt-p dark:bg-darkmode-txt-p" />
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-12 rounded-[36px] border border-border/40 bg-bg-s/40 p-8 text-left dark:border-darkmode-border/40 dark:bg-darkmode-bg-s/40">
        <h3 class="text-xl font-semibold text-txt-p dark:text-darkmode-txt-p">
          You’ll complete practical milestones each week:
        </h3>
        <ul class="mt-4 grid gap-3 md:grid-cols-2 text-sm leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
          {outcomes.map((outcome) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 inline-block h-2 w-2 rounded-full bg-txt-p dark:bg-darkmode-txt-p" />
              <span>{outcome}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="row justify-center text-center mb-10">
        <div class="lg:col-8">
          <h2 class="text-3xl font-semibold text-txt-p dark:text-darkmode-txt-p">
            Retreat intensives & hybrid mentorship
          </h2>
          <p class="mt-3 text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
            Choose your in-person immersion and stay plugged into the field with 90 days of online support, practicum labs, and business coaching.
          </p>
        </div>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {retreats.map((retreat) => (
          <div class="glass h-full rounded-3xl border border-border/40 p-6 text-left dark:border-darkmode-border/40">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-txt-light dark:text-darkmode-txt-light">
              {retreat.date}
            </p>
            <h3 class="mt-3 text-xl font-semibold text-txt-p dark:text-darkmode-txt-p">
              {retreat.title}
            </h3>
            <p class="mt-2 text-sm text-txt-light dark:text-darkmode-txt-light">
              {retreat.location}
            </p>
            <p class="mt-4 text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
              {retreat.focus}
            </p>
            <div class="mt-6">
              <Button
                label="Reserve your seat"
                link="https://wa.me/9779702694437"
                newtab
              />
            </div>
          </div>
        ))}
      </div>
      <div class="mt-10 rounded-3xl border border-accent/40 bg-accent/5 p-6 text-sm leading-relaxed text-txt-p/80 dark:border-accent/30 dark:bg-accent/10 dark:text-darkmode-txt-p/80">
        <strong class="text-txt-p dark:text-darkmode-txt-p">Lead magnet idea:</strong> Offer a “Singing Bowl Sequence for Nervous System Reset” PDF or audio to capture emails from visitors not ready to book a flight yet. Build the form in ConvertKit and embed it here once the asset is recorded.
      </div>
    </div>
  </section>

  {featuredServices.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="row justify-center text-center mb-10">
          <div class="lg:col-8">
            <h2 class="text-3xl font-semibold text-txt-p dark:text-darkmode-txt-p">
              Stay plugged into Christina’s field
            </h2>
            <p class="mt-3 text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
              Pair the training with Christina’s signature ceremonies so your body integrates the frequency firsthand—virtually or in Kathmandu.
            </p>
          </div>
        </div>
        <div class={featuredServicesGridClass}>
          {featuredServices.map((service) => (
            <Card entry={service} />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="row justify-center text-center mb-10">
        <div class="lg:col-8">
          <h2 class="text-3xl font-semibold text-txt-p dark:text-darkmode-txt-p">
            Frequently asked questions
          </h2>
          <p class="mt-3 text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
            These answers mirror the exact phrases people ask in Google’s AI Overviews so your cohort lands in the snapshot.
          </p>
        </div>
      </div>
      <div class="mx-auto flex max-w-4xl flex-col gap-6">
        {faqs.map((faq) => (
          <details class="group rounded-3xl border border-border/40 bg-bg-s/30 p-6 text-left transition dark:border-darkmode-border/40 dark:bg-darkmode-bg-s/30">
            <summary class="cursor-pointer text-lg font-semibold text-txt-p dark:text-darkmode-txt-p">
              {faq.question}
            </summary>
            <p class="mt-4 text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
              {faq.answer}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section pb-20">
    <div class="container">
      <div class="glass mx-auto max-w-5xl rounded-[36px] border border-border/40 p-10 text-center dark:border-darkmode-border/40">
        <h2 class="text-3xl font-semibold text-txt-p dark:text-darkmode-txt-p">
          Ready to hold the field as a sound healer?
        </h2>
        <p class="mt-4 text-base leading-relaxed text-txt-p/80 dark:text-darkmode-txt-p/80">
          Share your intention, location, and experience level. Christina will reply with available cohort seats, payment plans in NPR or USD, and prep rituals to start tuning your vibration today.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-4">
          <Button
            label="Message the Kathmandu sanctuary"
            link="https://wa.me/9779702694437"
            newtab
          />
          <Button
            label="Email the team"
            link="mailto:hello@tuneyourvibration.com"
            type="secondary"
          />
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline>
    {schemaPayloads.course}
  </script>
  <script type="application/ld+json" is:inline>
    {schemaPayloads.faq}
  </script>
</BaseLayout>
